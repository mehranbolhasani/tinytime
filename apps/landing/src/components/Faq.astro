---
const faq = [
  {
    q: 'Is tinytime free?',
    a: 'Yes. tinytime is currently free to use.',
  },
  {
    q: 'Where is my data stored?',
    a: 'Data is stored in your app database on Supabase and scoped with row-level security.',
  },
  {
    q: 'Can I export my entries?',
    a: 'Yes. Reports include CSV export for your selected date range.',
  },
  {
    q: 'What does the Google Calendar integration do?',
    a: 'It overlays read-only Google Calendar events in the calendar day view so you can compare planned vs tracked time.',
  },
]
---

<section class="py-12 sm:py-16">
  <div class="tiny-container">
    <h2 class="text-2xl font-semibold sm:text-3xl">FAQ</h2>
    <div class="mt-6 grid gap-4">
      {faq.map((item) => (
        <article class="tiny-card p-5">
          <h3 class="text-base font-semibold">{item.q}</h3>
          <p class="mt-2 text-sm text-[var(--tiny-muted)]">{item.a}</p>
        </article>
      ))}
    </div>
  </div>
</section>
