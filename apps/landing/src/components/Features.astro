---
import { Clock3, CalendarDays, FolderKanban, ChartColumn, LogIn, CalendarSync } from '@lucide/astro';

const features = [
  { label: 'One-click timer', icon: Clock3 },
  { label: 'Calendar view', icon: CalendarDays },
  { label: 'Project and tags', icon: FolderKanban },
  { label: 'Reports', icon: ChartColumn },
  { label: 'Google and GitHub sign-in', icon: LogIn },
  { label: 'Google Calendar integration', icon: CalendarSync },
]
---

<section id="features" class="py-24">
  <div class="tiny-container">
    <h2 class="text-2xl text-center font-light">Everything you need, <br> nothing else.</h2>
    <div class="mt-6 grid gap-4 grid-cols-2">
      {features.map((feature) => {
        const Icon = feature.icon;

        return (
          <article class="bg-card px-4 py-4 rounded-2xl flex items-center gap-2 shadow-lg shadow-primary/5">
            <Icon size={20} stroke-width={1.5} />
            <p class="text-sm text-[var(--tiny-fg)]">{feature.label}</p>
          </article>
        );
      })}
    </div>
  </div>
</section>
