---
import Layout from '../components/Layout.astro'
import '../styles/global.css'
---

<Layout
  title="Terms of Use — tinytime"
  description="Terms of use for tinytime."
  path="/terms"
>
  <section class="py-16">
    <div class="tiny-container max-w-3xl">
      <h1 class="text-3xl font-semibold">Terms of Use</h1>
      <p class="mt-2 text-sm text-[var(--tiny-muted)]">Last updated: April 23, 2026</p>

      <div class="mt-8 space-y-6 text-sm leading-7 text-[var(--tiny-fg)]">
        <section>
          <h2 class="text-lg font-semibold">Service scope</h2>
          <p class="mt-2 text-[var(--tiny-muted)]">
            tinytime is a personal time-tracking web app provided on an "as is" and "as available" basis.
          </p>
        </section>

        <section>
          <h2 class="text-lg font-semibold">Accounts and security</h2>
          <p class="mt-2 text-[var(--tiny-muted)]">
            You are responsible for maintaining control of your sign-in email account and any third-party
            provider connections (Google/GitHub).
          </p>
        </section>

        <section>
          <h2 class="text-lg font-semibold">Acceptable use</h2>
          <p class="mt-2 text-[var(--tiny-muted)]">
            You may not misuse the service, attempt unauthorized access, interfere with operations, or use
            tinytime for unlawful purposes.
          </p>
        </section>

        <section>
          <h2 class="text-lg font-semibold">Termination</h2>
          <p class="mt-2 text-[var(--tiny-muted)]">
            Access may be suspended or terminated if abuse, security risk, or legal requirements demand it.
          </p>
        </section>

        <section>
          <h2 class="text-lg font-semibold">Limitation of liability</h2>
          <p class="mt-2 text-[var(--tiny-muted)]">
            To the maximum extent permitted by law, tinytime is not liable for indirect, incidental, or
            consequential damages arising from use of the service.
          </p>
        </section>

        <section>
          <h2 class="text-lg font-semibold">Changes</h2>
          <p class="mt-2 text-[var(--tiny-muted)]">
            These terms may be updated over time. Continued use after updates means you accept the revised
            terms.
          </p>
        </section>

        <section>
          <h2 class="text-lg font-semibold">Contact</h2>
          <p class="mt-2 text-[var(--tiny-muted)]">
            Questions about these terms can be sent to
            <a class="tiny-link" href="mailto:legal@tinytime.work">legal@tinytime.work</a>.
          </p>
        </section>
      </div>
    </div>
  </section>
</Layout>
